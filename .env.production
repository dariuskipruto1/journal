# === PRODUCTION ENVIRONMENT ===
# Use this for Heroku or other production deployments

# Django settings
DJANGO_SECRET_KEY=your-production-secret-key-change-this-before-deploying
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.heroku.com,www.yourdomain.com

# Database
# Leave empty to use Heroku Postgres (automatically configured)
# Or set DATABASE_URL for custom database

# Email settings - Configure for your email provider
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@journaldesk.io
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=your-email@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-app-specific-password

# Task alerts
TASK_ALERTS_EMAIL_ENABLED=True
TASK_ALERTS_WHATSAPP_ENABLED=False

# Ollama AI settings (use remote instance or cloud AI service)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4
OLLAMA_TIMEOUT_SECONDS=30

# Weather settings
WEATHER_DEFAULT_LOCATION=Nairobi

# Cloud Storage (AWS S3) - Optional but recommended
# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# Redis Cache - Optional
# REDIS_URL=redis://user:password@host:6379/0

# Celery - Optional
# CELERY_BROKER_URL=redis://user:password@host:6379/1
