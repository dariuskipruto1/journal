# Django settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Uses SQLite by default, no configuration needed

# Email settings
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@journal.local
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=your-email@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-app-password
DJANGO_EMAIL_USE_TLS=True

# Task alerts
TASK_ALERTS_EMAIL_ENABLED=True
TASK_ALERTS_WHATSAPP_ENABLED=False

# WhatsApp (Twilio) settings
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Ollama AI settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_FALLBACK_MODELS=llama2,llama3.2,mistral,qwen2.5

# Weather settings
WEATHER_DEFAULT_LOCATION=Nairobi

# ============ PUSH NOTIFICATIONS ============
FCM_API_KEY=your-firebase-cloud-messaging-key
APNS_CERTIFICATE=/path/to/apns/certificate.pem

# ============ VOICE ENTRY TRANSCRIPTION ============
TRANSCRIPTION_SERVICE=google
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google/credentials.json
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ============ AWS S3 CONFIGURATION ============
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ============ GOOGLE CLOUD STORAGE ============
GCP_PROJECT_ID=
GCP_CREDENTIALS_FILE=
GCP_BUCKET_NAME=

# ============ CLOUD BACKUP SETTINGS ============
AUTO_BACKUP_ENABLED=True
BACKUP_INTERVAL_HOURS=24

# ============ CALENDAR INTEGRATION ============
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/calendar/callback/

OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/calendar/callback/

# ============ SOCIAL SHARING ============
TWITTER_API_KEY=
TWITTER_API_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_API_KEY=
LINKEDIN_API_SECRET=

# ============ REDIS CONFIGURATION ============
REDIS_URL=redis://localhost:6379/0

# ============ CELERY CONFIGURATION ============
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
USE_CELERY=False

# ============ EMAIL REMINDERS ============
EMAIL_CHECK_INTERVAL=15

# ============ CORS CONFIGURATION ============
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============ MOBILE APP CONFIGURATION ============
API_BASE_URL=http://localhost:8000/api/
IOS_APP_ID=com.yourcompany.journaldesk
ANDROID_APP_ID=com.yourcompany.journaldesk

# ============ ERROR TRACKING (Sentry) ============
SENTRY_DSN=
